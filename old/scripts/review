#!/usr/bin/env python3
"""Code review tool for NemoClaw sandbox.
Reads endpoint and model from environment variables."""

import json
import os
import sys
import urllib.request

os.environ["no_proxy"] = "*"

RELAY_BIND_IP = os.environ.get("RELAY_BIND_IP", "10.200.0.1")
VLLM_PORT = os.environ.get("VLLM_PORT", "8000")
MODEL_NAME = os.environ.get("MODEL_NAME", "nvidia/NVIDIA-Nemotron-Nano-9B-v2-Japanese")

if len(sys.argv) < 2:
    print("Usage: ~/review <file>")
    sys.exit(1)

code = open(sys.argv[1]).read()
prompt = "Review this file and suggest improvements. Be specific:\n\n" + code
body = json.dumps({
    "model": MODEL_NAME,
    "messages": [{"role": "user", "content": prompt}],
    "max_tokens": 4096,
}).encode()
req = urllib.request.Request(
    f"http://{RELAY_BIND_IP}:{VLLM_PORT}/v1/chat/completions",
    data=body,
    headers={"Content-Type": "application/json", "Authorization": "Bearer dummy"},
)
r = json.load(urllib.request.urlopen(req))
c = r["choices"][0]["message"]
print(c.get("content") or c.get("reasoning_content", "No response"))
